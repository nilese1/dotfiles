#!/bin/bash
alias get_idf='. $HOME/esp/esp-idf/export.sh'
alias wallpapers='~/Pictures/wallpapers/'
alias dotfiles='/usr/bin/git --git-dir=$HOME/.dotfiles/ --work-tree=$HOME'

# pyton
alias pyvenv="source ./.venv/bin/activate"
alias pyvenv-create='python3 -m venv venv'

# clipboard (head for deleting newline character at the end of every bash command)
alias clip="head -c -1 | xclip -selection clipboard -i"

# OH MEIN GOODDTTT
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias .....="cd ../../../.."
